# Copy to .env for local development.

# Base hostname the app serves. The bare hostname is the apex; subdomains
# match site routes (`<slug>.<JOTTIT_DOMAIN>`). localtest.me is a public DNS
# alias where `*.localtest.me` resolves to 127.0.0.1, so subdomain routing
# works locally without /etc/hosts edits.
JOTTIT_DOMAIN=localtest.me:5000

# Postgres. Empty user/host uses Unix socket + peer auth (the default
# when you `brew install postgresql@16 && brew services start postgresql@16`
# on macOS). Fly emits `postgres://` URLs; make_engine normalizes them.
DATABASE_URL=postgresql+psycopg:///jottit_dev

# Flask session signing key. Required in production; anything random works locally.
SECRET_KEY=dev-not-secret-replace-me

# Cloudflare Turnstile keys (anti-spam on open-edit sites).
# https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITEKEY=
TURNSTILE_SECRET=

# Resend API key + From: address. Outbound mail falls back to an
# in-process outbox when either is unset (dev + tests).
# https://resend.com/api-keys
RESEND_API_KEY=
MAIL_FROM=
